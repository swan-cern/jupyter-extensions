{
  "name": "swan-ml",
  "version": "0.4.3",
  "description": "JupyterLab sidebar showing ml.cern.ch pipeline run status",
  "license": "MIT",
  "author": "SWAN Team",
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}",
    "style/**/*.{css,eot,gif,html,jpg,json,png,svg,woff2,ttf}"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://gitlab.cern.ch/swan/swan-ml.git"
  },
  "scripts": {
    "build": "jlpm build:lib && jlpm build:labextension:dev",
    "build:prod": "jlpm clean && jlpm build:lib:prod && jlpm build:labextension",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "clean": "jlpm clean:lib && jlpm clean:labextension",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "clean:labextension": "rimraf swan_ml/labextension swan_ml/_version.py",
    "watch": "run-p watch:src watch:labextension",
    "watch:src": "tsc -w --sourceMap",
    "watch:labextension": "jupyter labextension watch .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"style/**/*.css\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"style/**/*.css\"",
    "lint": "jlpm lint:eslint && jlpm lint:stylelint && jlpm format:check",
    "lint:fix": "jlpm eslint:fix && jlpm stylelint:fix && jlpm format",
    "lint:eslint": "eslint \"src/**/*.{ts,tsx}\"",
    "eslint:fix": "eslint --fix \"src/**/*.{ts,tsx}\"",
    "lint:stylelint": "stylelint \"style/**/*.css\"",
    "stylelint:fix": "stylelint --fix \"style/**/*.css\""
  },
  "dependencies": {
    "@jupyterlab/application": "~4.5.6",
    "@jupyterlab/apputils": "~4.6.6",
    "@jupyterlab/coreutils": "~6.5.6",
    "@jupyterlab/services": "~7.5.6",
    "@jupyterlab/ui-components": "~4.5.6",
    "@lumino/widgets": "~2.7.5"
  },
  "devDependencies": {
    "@eslint/js": "~10.0.0",
    "@jupyterlab/builder": "~4.5.6",
    "eslint": "~10.2.0",
    "eslint-config-prettier": "~10.1.8",
    "eslint-plugin-react": "~7.37.5",
    "eslint-plugin-react-hooks": "~7.1.0",
    "globals": "~17.5.0",
    "npm-run-all": "~4.1.5",
    "prettier": "~3.8.3",
    "rimraf": "~6.1.3",
    "stylelint": "~17.8.0",
    "stylelint-config-standard": "~40.0.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "~8.59.0"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "swan_ml/labextension"
  }
}
